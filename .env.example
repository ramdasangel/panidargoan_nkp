# Copy this file to .env and fill in real values for production.
# For local development, the defaults below work with docker-compose.

# Database
POSTGRES_USER=panidargoan
POSTGRES_PASSWORD=panidargoan
POSTGRES_DB=panidargoan
DATABASE_URL=postgresql://panidargoan:panidargoan@localhost:5433/panidargoan

# API
API_PORT=3000
JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
# dummy | google | both
AUTH_MODE=both

# Google Sign-In: paste the Client ID from your OAuth client (Cloud Console).
# The secret stays in client_secret_*.json (gitignored). With ID-token
# verification we only need the client ID server-side.
GOOGLE_CLIENT_ID=
# Comma-separated Google emails that get the admin role on first sign-in.
ADMIN_EMAILS=

# Web
VITE_API_URL=http://localhost:3000
